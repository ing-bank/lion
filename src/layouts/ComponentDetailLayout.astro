---
import DetailLayout from "./DetailLayout.astro";

const { title, componentName, description = "Accessible component with various states and styles.", components = [], headings = [] } = Astro.props;

// Group components by category
const componentsByCategory = new Map();
components.forEach(component => {
  const [compName] = component.href.split('/').filter(p => p && p !== 'components');
  const category = compName || 'other';
  
  if (!componentsByCategory.has(category)) {
    componentsByCategory.set(category, []);
  }
  componentsByCategory.get(category).push({
    href: component.href,
    label: component.label,
  });
});
---

<DetailLayout
  title={title}
  activeNavItem="components"
  sectionName="Components"
  itemName={componentName}
  description={description}
  backLink={`${import.meta.env.BASE_URL}/components/`}
  backLinkLabel="← Back to Overview"
  itemsByCategory={componentsByCategory}
  headings={headings}
>
  <slot />
</DetailLayout>
