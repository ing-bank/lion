---
import { SEO } from "astro-seo";
import TopNav from "../components/TopNav.astro";

const site = Astro.site || Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", site).toString();
const { title, componentName, description = "Accessible component with various states and styles.", components = [], headings = [] } = Astro.props;
---

<style>
  .docs-sidebar {
    width: 240px;
    padding-right: 1rem;
    border-right: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .component-nav h3 {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #666;
    margin: 1rem 0 0.75rem 0;
    padding: 0 1rem;
  }

  .component-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .category-item {
    display: block;
  }

  .category-toggle {
    display: block;
    width: 100%;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    color: #666;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: left;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s ease;
    position: relative;
    padding-left: 1.5rem;
  }

  .category-toggle:before {
    content: '▼';
    position: absolute;
    left: 0.5rem;
    font-size: 0.6rem;
    transition: transform 0.2s ease;
  }

  .category-toggle[aria-expanded="false"]:before {
    transform: rotate(-90deg);
  }

  .category-toggle:hover {
    color: #333;
  }

  .category-submenu {
    list-style: none;
    margin: 0;
    padding: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    max-height: 1000px;
    opacity: 1;
    overflow: hidden;
  }

  .category-submenu.collapsed {
    max-height: 0;
    opacity: 0;
  }

  .component-item {
    display: block;
  }

  .component-link {
    display: block;
    padding: 0.5rem 1rem;
    color: #333;
    text-decoration: none;
    font-size: 0.875rem;
    border-left: 3px solid transparent;
    transition: all 0.2s ease;
    margin-left: 0.5rem;
  }

  .component-link:hover {
    background-color: #f5f5f5;
    color: #000;
  }

  .component-link.active {
    color: #0066cc;
    background-color: #f0f7ff;
    border-left-color: #0066cc;
    font-weight: 500;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 240px 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  .docs-content {
    grid-column: 2;
  }

  .docs-toc {
    grid-column: 3;
    position: sticky;
    top: 20px;
    height: fit-content;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
  }

  @media (max-width: 1200px) {
    .docs-layout {
      grid-template-columns: 240px 1fr;
    }
    .docs-toc {
      display: none;
    }
  }
</style>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="view-transition" content="same-origin" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href=`${import.meta.env.BASE_URL}/favicon.svg` />
    <meta name="generator" content={Astro.generator} />
    
    <link rel="stylesheet" href=`${import.meta.env.BASE_URL}/styles/styles.css`>
    <link rel="stylesheet" href=`${import.meta.env.BASE_URL}/styles/components.css`>
    <link rel="stylesheet" href=`${import.meta.env.BASE_URL}/styles/transitions.css`>
    <link rel="stylesheet" href=`${import.meta.env.BASE_URL}/styles/scroll-animations.css`>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: title,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: `${componentName} component documentation`,
        },
      }}
    />
    <script src="../components/ui-portal-inpage-nav.js"></script>
</head>
<body>
    <div class="scroll-progress"></div>
    <div class="grid-background"></div>
    
    <TopNav activeNavItem="components" />

    <main>
        <div class="container">
            <div class="docs-layout">
                <aside class="docs-sidebar">
                    <a href=`${import.meta.env.BASE_URL}/components/` class="back-link">← Back to Overview</a>
                    <nav class="component-nav">
                        <h3>Components</h3>
                        <ul>
                            {components.map((component) => {
                                // Extract category from href (e.g., /components/buttons/button/ → buttons)
                                const parts = component.href.split('/').filter(p => p && p !== 'components');
                                const category = parts[0];
                                const isActive = componentName === component.name;
                                
                                return (
                                    <li class={`component-item ${isActive ? 'active' : ''}`}>
                                        <a href={`${import.meta.env.BASE_URL}${component.href.replace(/\/$/, '')}`} class={`component-link ${isActive ? 'active' : ''}`} data-category={category}>
                                            {component.label}
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    </nav>
                </aside>

                <div class="docs-content">
                    <slot />
                </div>

                <aside class="docs-toc">
                    <ui-portal-inpage-nav nav-data={JSON.stringify(headings)}></ui-portal-inpage-nav>
                </aside>
            </div>
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-row">
                <div class="footer-brand">
                    <img src=`${import.meta.env.BASE_URL}/lionui-text.svg` alt="lion ui" height="16" class="logo-text-svg">
                    <p class="copyright">&copy; 2025 Lion Project. MIT License.</p>
                </div>
                <div class="footer-links">
                    <a href=`${import.meta.env.BASE_URL}/blog/`>Blog</a>
                    <a href="https://github.com/ing-bank/lion/issues">Help</a>
                    <a href="https://github.com/ing-bank/lion">GitHub</a>
                    <a href=`${import.meta.env.BASE_URL}/about/slack/`>Slack</a>
                    <a href="https://github.com/ing-bank/lion/blob/master/CONTRIBUTING.md">Contribute</a>
                </div>
            </div>
        </div>
    </footer>
</body>

<script>
  // Group components by category and make them collapsible
  const nav = document.querySelector('.component-nav ul');
  if (nav) {
    const items = Array.from(nav.querySelectorAll('.component-item'));
    const categories = new Map();

    // Group items by category
    items.forEach(item => {
      const link = item.querySelector('.component-link');
      const category = link?.dataset.category || 'other';
      
      if (!categories.has(category)) {
        categories.set(category, []);
      }
      categories.get(category).push(item);
    });

    // Clear and rebuild with categories
    nav.innerHTML = '';
    
    categories.forEach((items, category) => {
      // Create category toggle
      const categoryItem = document.createElement('li');
      categoryItem.className = 'category-item';
      
      const categoryToggle = document.createElement('button');
      categoryToggle.className = 'category-toggle';
      categoryToggle.textContent = category.charAt(0).toUpperCase() + category.slice(1);
      categoryToggle.setAttribute('data-category', category);
      categoryToggle.setAttribute('aria-expanded', 'true');
      
      categoryItem.appendChild(categoryToggle);
      nav.appendChild(categoryItem);
      
      // Create submenu for items
      const submenu = document.createElement('ul');
      submenu.className = 'category-submenu';
      submenu.setAttribute('data-category', category);
      
      items.forEach(item => {
        submenu.appendChild(item);
      });
      
      nav.appendChild(submenu);
      
      // Toggle handler
      categoryToggle.addEventListener('click', (e) => {
        e.preventDefault();
        const isExpanded = categoryToggle.getAttribute('aria-expanded') === 'true';
        categoryToggle.setAttribute('aria-expanded', !isExpanded);
        submenu.classList.toggle('collapsed');
        
        // Persist state
        localStorage.setItem(`category-${category}`, !isExpanded ? 'expanded' : 'collapsed');
      });
      
      // Restore previous state
      const savedState = localStorage.getItem(`category-${category}`);
      if (savedState === 'collapsed') {
        categoryToggle.setAttribute('aria-expanded', 'false');
        submenu.classList.add('collapsed');
      }
    });
  }
</script>
