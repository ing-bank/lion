// Add search and github to navData
navData.push(
  {
    name: 'Search',
    url: '/search',
    svg: searchSvg,
  },
  {
    name: 'GitHub',
    url: 'https://github.com/ing-bank/lion',
    svg: githubSvg,
    target: '_blank',
    rel: 'noopener noreferrer',
  }
);

/** @type WeakMap<{NavItem},{NavItem}> */
const itemParents = new WeakMap();

function _setParentsActive(navItem) {
  const parentItem = itemParents.get(navItem);
  if (parentItem) {
    parentItem.hasActiveChild = true;
    _setParentsActive(parentItem);
  }
}

function setParents(navData, parentItem = null) {
  for (const navItem of navData) {
    if (parentItem) {
      itemParents.set(navItem, parentItem);
    }
    if (navItem.children?.length) {
      setParents(navItem.children, navItem);
    }
  }
}

let activeItem;
function setActive(navData, currentUrl) {
  // for home page we need to check with the exact match
  const isActive = (navItem) => {
    if (navItem.url === import.meta.env.BASE_URL) {
      // homepage
      return `${navItem.url}/` === currentUrl;
    }

    // /components/form
    // /components/form-input problem
    return `${currentUrl}/`.startsWith(`${navItem.url}/`);
  }

  for (const navItem of navData) {
    if (isActive(navItem)) {
      navItem.active = true;
      activeItem = navItem;
    }
    if (navItem.children?.length) {
      setActive(navItem.children, currentUrl);
    }
  }
}

setParents(navData);
setActive(navData, Astro.url.pathname);
_setParentsActive(activeItem);

const { variant } = Astro.props;
---

<style>
  .site-header {
    padding: 0;
    background: var(--background-primary);
    border-bottom: 1px solid var(--border-color, #e2e8f0);
  }

  .container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    flex-grow: 0;
  }

  .logo:hover {
    text-decoration: none;
  }

  .logo-text-svg {
    /* Removed grayscale filter to keep logo intact */
  }

  :global(.site-header ui-portal-main-nav) {
    flex: 1;
    height: auto;
  }

</style>

<header class="site-header">
    <div class="container">
        <a href=`${import.meta.env.BASE_URL}` class="logo">
            <img src=`${import.meta.env.BASE_URL}/logo.svg` alt="Lion Logo" width="32" height="32">
            <img src=`${import.meta.env.BASE_URL}/lionui-text.svg` alt="lion ui" height="16" class="logo-text-svg">
        </a>
        
        <UIPortalMainNav 
          client:load 
          nav-data={JSON.stringify({ items: navData })} 
          variant={variant}
        />
    </div>
</header>

<script>
  // Set up search button event listener
  const setupSearchButton = () => {
    // Wait for UIPortalMainNav to be rendered
    const findSearchButton = () => {
      // Look for the search button in the UIPortalMainNav
      const navElement = document.querySelector('ui-portal-main-nav');
      if (!navElement) {
        // Retry if nav element not found yet
        setTimeout(findSearchButton, 100);
        return;
      }

      // Access shadow DOM to find search button
      const shadowRoot = navElement.shadowRoot;
      if (!shadowRoot) {
        setTimeout(findSearchButton, 100);
        return;
      }

      // Find the search button - look for element with text "Search" or aria-label containing "search"
      const searchLink = Array.from(shadowRoot.querySelectorAll('a, button')).find(el => {
        const text = el.textContent?.toLowerCase();
        const ariaLabel = el.getAttribute('aria-label')?.toLowerCase();
        return text?.includes('search') || ariaLabel?.includes('search');
      });

      if (searchLink) {
        searchLink.addEventListener('click', (e) => {
          e.preventDefault();
          // Dispatch custom event that SearchModal listens for
          document.dispatchEvent(new CustomEvent('search-requested'));
        });
      } else {
        // Retry if search button not found yet
        setTimeout(findSearchButton, 100);
      }
    };

    // Start looking for the button
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', findSearchButton);
    } else {
      findSearchButton();
    }
  };

  setupSearchButton();
</script>

<SearchModal />