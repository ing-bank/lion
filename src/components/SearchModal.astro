---
import Search from "astro-pagefind/components/Search";

interface Props {
  uiOptions?: Record<string, any>;
}

const { uiOptions = { showImages: false } } = Astro.props as Props;
---

<style>
  dialog#searchModal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 700px;
    padding: 40px;
    background-color: #0a0a0a;
    border: none;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    z-index: 1000;
    animation: slideIn 0.3s ease-out;
  }

  dialog#searchModal::backdrop {
    background-color: rgba(0, 0, 0, 0.7);
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translate(-50%, -55%);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }

  .search-modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: #ffffff;
    font-size: 28px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .search-modal-close:hover {
    color: #FFC107;
  }

  .search-header {
    margin-bottom: 30px;
  }

  .search-header h2 {
    font-size: 1.8rem;
    margin-bottom: 8px;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    font-weight: 800;
  }

  .search-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  :global(dialog#searchModal .pagefind-ui) {
    --pagefind-ui-primary: #FFC107;
    --pagefind-ui-text: #ffffff;
    --pagefind-ui-background: #0a0a0a;
    --pagefind-ui-border: #222222;
    --pagefind-ui-border-width: 1px;
  }

  @media (max-width: 600px) {
    dialog#searchModal {
      width: 95%;
      padding: 20px;
      padding-top: 50px;
    }

    .search-header h2 {
      font-size: 1.3rem;
    }
  }
</style>

<dialog id="searchModal">
  <button class="search-modal-close" id="closeSearchModal" aria-label="Close search">
    ×
  </button>
  <div class="search-header">
    <h2>Search</h2>
    <p>Find components, guides, and documentation</p>
  </div>
  <Search id="search" className="pagefind-ui" uiOptions={uiOptions} client:load />
</dialog>

<script>
  // Ensure DOM is ready before initializing
  const initializeSearchModal = () => {
    const searchModal = document.getElementById("searchModal") as HTMLDialogElement;
    const closeSearchModal = document.getElementById("closeSearchModal");

    if (!searchModal) {
      console.warn("SearchModal: #searchModal element not found");
      return;
    }

    // Open modal when search event is dispatched
    document.addEventListener('search-requested', () => {
      searchModal.showModal();
      // Focus the search input
      setTimeout(() => {
        const input = document.querySelector("dialog#searchModal .pagefind-ui input");
        if (input) (input as HTMLInputElement).focus();
      }, 100);
    });

    // Close modal when close button is clicked
    if (closeSearchModal) {
      closeSearchModal.addEventListener("click", () => {
        searchModal.close();
      });
    }

    // Close modal when clicking outside the content (on the backdrop)
    searchModal.addEventListener("click", (e) => {
      if (e.target === searchModal) {
        searchModal.close();
      }
    });
  };

  // Initialize when DOM is ready or immediately if DOM is already loaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeSearchModal);
  } else {
    initializeSearchModal();
  }
</script>
