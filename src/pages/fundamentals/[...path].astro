---
import { getCollection, getEntry, render } from "astro:content";
import DetailLayout from "../../layouts/DetailLayout.astro";

export async function getStaticPaths() {
    const entries = await getCollection("lionFundamentals");

    return [
        ...entries.map(entry => ({ params: { path: entry.id }})),
        {params: { path: undefined }}
    ]
}

const { path } = Astro.params;
const entry = await getEntry("lionFundamentals", path);

if (!entry) {
    // Handle Error, for example:
    throw new Error(`Could not find fundamental by URL ${path}`);
}

const { remarkPluginFrontmatter, Content, headings } = await render(entry);

const loadDemoAttributes = {};
if (remarkPluginFrontmatter.mdjsStoriesPath) {
  loadDemoAttributes['data-import-path'] = remarkPluginFrontmatter.mdjsStoriesPath;
}

// Extract fundamental name from path for sidebar highlighting
const fundamentalName = path?.split('/')[0] || path;

// Get display name from entry data or fallback to path
const displayName = entry.data?.title || fundamentalName?.charAt(0).toUpperCase() + fundamentalName?.slice(1) || 'Fundamental';

// Build fundamentals list for sidebar navigation
const allFundamentals = await getCollection("lionFundamentals");
const fundamentalsByCategory = new Map();

allFundamentals
  .filter(fundamental => fundamental.id !== 'index') // Exclude the index page from sidebar
  .forEach(fundamental => {
    const [category] = fundamental.id.split('/');
    const fundamentalPath = fundamental.id;
    const name = fundamental.id.split('/').pop() || fundamental.id;
    const label = fundamental.data?.title || name?.charAt(0).toUpperCase() + name?.slice(1) || 'Fundamental';

    if (!fundamentalsByCategory.has(category)) {
      fundamentalsByCategory.set(category, []);
    }
    
    fundamentalsByCategory.get(category).push({
      href: `/fundamentals/${fundamentalPath}/`,
      label,
    });
  });

// Sort categories and their items
const sortedCategories = new Map(
  Array.from(fundamentalsByCategory.entries())
    .sort(([catA], [catB]) => catA.localeCompare(catB))
    .map(([category, items]) => [
      category,
      items.sort((a, b) => a.label.localeCompare(b.label))
    ])
);
---

<DetailLayout
  title={`${displayName} - Lion UI`}
  activeNavItem="fundamentals"
  sectionName="Fundamentals"
  itemName={fundamentalName}
  description={entry.data?.description || `${displayName} fundamental.`}
  backLink={`${import.meta.env.BASE_URL}/fundamentals/`}
  backLinkLabel="← Back to Fundamentals"
  itemsByCategory={sortedCategories}
  headings={headings.map(h => ({ name: h.text, url: h.slug }))}
>
  <div class="docs-content__content fundamentals-content">
    <load-demo {...loadDemoAttributes}><Content /></load-demo>
  </div>

  <script>
    class LoadDemo extends HTMLElement {
      connectedCallback() {
        // a weird hack for Astro
        // in order to have script type=module, we cant specify any attributes to it
        // this MDJS breaks, because we need msjs-setup attribute
        // if we specify this attribute, then it's suddenly loses "type=module" and lazy import cannot be used inside

        // on top of that, to pass the variable from template (importPath) we can only do this through HTML element
        if (this.dataset.importPath) {
          import(`./_demos/${this.dataset.importPath}.js`);

          const currentScript = [...document.scripts].find(script => script.src === import.meta.url);
          currentScript.setAttribute('mdjs-setup', 'true');
          // another rocket - astro compatibility magic
          // we mast pass ".js" because it is stripped by rocket
          // so we get story file variable in simulator without it (as we want)
          currentScript.setAttribute('src', `/fundamentals/${this.dataset.importPath}`);
        }
      }
    }

    customElements.define('load-demo', LoadDemo);
  </script>
</DetailLayout>
