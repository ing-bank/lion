---
import { getEntry, render, getCollection } from "astro:content";
import DetailLayout from "../../layouts/DetailLayout.astro";

const entry = await getEntry('lionFundamentals','index');

const { Content, headings } = await render(entry);

// Build fundamentals list for sidebar navigation
const allFundamentals = await getCollection("lionFundamentals");
const fundamentalsByCategory = new Map();

allFundamentals
  .filter(fundamental => fundamental.id !== 'index') // Exclude the index page from sidebar
  .forEach(fundamental => {
    const [category] = fundamental.id.split('/');
    const fundamentalPath = fundamental.id;
    const name = fundamental.id.split('/').pop() || fundamental.id;
    const label = fundamental.data?.title || name?.charAt(0).toUpperCase() + name?.slice(1) || 'Fundamental';

    if (!fundamentalsByCategory.has(category)) {
      fundamentalsByCategory.set(category, []);
    }
    
    fundamentalsByCategory.get(category).push({
      href: `/fundamentals/${fundamentalPath}/`,
      label,
    });
  });

// Sort categories and their items
const sortedCategories = new Map(
  Array.from(fundamentalsByCategory.entries())
    .sort(([catA], [catB]) => catA.localeCompare(catB))
    .map(([category, items]) => [
      category,
      items.sort((a, b) => a.label.localeCompare(b.label))
    ])
);
---

<DetailLayout
  title="Fundamentals - Lion UI"
  activeNavItem="fundamentals"
  sectionName="Fundamentals"
  description="Fundamentals for building with Lion UI components"
  backLink={`${import.meta.env.BASE_URL}/`}
  backLinkLabel="← Back to Home"
  itemsByCategory={sortedCategories}
  headings={headings.map(h => ({ name: h.text, url: h.slug }))}
>
  <div class="docs-content__content fundamentals-content">
    <Content />
  </div>
</DetailLayout>
