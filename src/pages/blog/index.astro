---
import { getCollection, getEntry, render } from "astro:content";
import BlogOverviewLayout from "../../layouts/BlogOverviewLayout.astro";

const entries = await getCollection("lionBlog", entry => entry.data?.published);
const entry = await getEntry('lionBlog', 'index');

const getUrl = (post) => {
  const baseUrl = import.meta.env.BASE_URL;
  if (post.data?.url) {
    return `${baseUrl}/${post.data.url}`;
  }
  if (post.url) {
    return `${baseUrl}/${post.url}`;
  }
  return `${baseUrl}/blog/${post.id}`;
};

const { Content } = await render(entry);
---

<BlogOverviewLayout title="Lion Blog" description="Discover articles from the core team and contributors about Lion, tips and tricks included!">
  {entries.map((post) => (
    <article class="post-card" data-url={getUrl(post)}>
      {post.data.cover_image && <img src={post.data.cover_image} alt={post.data.title} class="post-image" />}

      <div class="post-content">
        <div class="post-meta">
          <span class="post-date">{new Date(post.data.date || new Date()).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          {post.data.tags && post.data.tags.length > 0 && (
            <span class="post-tag">{Array.isArray(post.data.tags) ? post.data.tags[0] : post.data.tags.split(',')[0].trim()}</span>
          )}
        </div>
        <h3 class="post-title">
          <a href={getUrl(post)}>{post.data.title}</a>
        </h3>
        <p class="post-excerpt">{post.data.description}</p>
        <a class="read-more" href={getUrl(post)}>Read more →</a>
      </div>
    </article>
  ))}
</BlogOverviewLayout>
